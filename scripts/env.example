# ocpp-cp-admin — Environment file for systemd EnvironmentFile=
# Copy to /etc/ocpp-cp-admin/env and set chmod 600
#
# These variables override the values in config/config.json.
# Only the variables relevant to your deployment need to be set.

# ── Déploiement / URLs ──────────────────────────────────────────────────────
# URL publique de l'interface web (utilisée dans les liens des notifications)
CPADMIN_PUBLIC_URL=https://cpadmin.example.com

# Adresse d'écoute HTTP (0.0.0.0 pour toutes les interfaces)
CPADMIN_HTTP_HOST=0.0.0.0

# Faire confiance au reverse proxy pour les en-têtes X-Forwarded-* (true/false)
CPADMIN_TRUST_PROXY=true

# URL WebSocket OCPP non chiffré (bornes sans TLS)
CPADMIN_OCPP_WS_URL=ws://ws.cpadmin.example.com

# URL WebSocket OCPP chiffré, TLS terminé par le reverse proxy
CPADMIN_OCPP_WSS_URL=wss://ws.cpadmin.example.com

# URL FTP où les bornes déposent leurs fichiers de diagnostic
#CPADMIN_DIAGNOSTICS_URL=ftp://ftp.cpadmin.example.com

# ── Sécurité ────────────────────────────────────────────────────────────────
# OBLIGATOIRE : secret de session (min. 32 caractères aléatoires)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPADMIN_SESSION_SECRET=change-me-with-a-random-secret-of-at-least-32-chars

# ── Activation des fonctionnalités ─────────────────────────────────────────
# Activer HTTPS pour l'interface web (nécessite certFile/keyFile dans config.json)
#CPADMIN_WEBUI_HTTPS_ENABLED=true

# Activer le serveur WebSocket OCPP chiffré (WSS natif, TLS terminé par le serveur)
#CPADMIN_OCPP_WSS_ENABLED=true

# ── Comportement OCPP ───────────────────────────────────────────────────────
# Activer le support OCPP 1.6
#CPADMIN_OCPP_V16_ENABLED=true

# Activer le support OCPP 2.0.1
#CPADMIN_OCPP_V201_ENABLED=false

# Mode strict OCPP (rejet des messages non conformes)
CPADMIN_OCPP_STRICT_MODE=false

# Ajouter automatiquement les bornes inconnues
CPADMIN_OCPP_AUTO_ADD=true

# Mettre les bornes inconnues en attente (nécessite OCPP_AUTO_ADD=false)
CPADMIN_OCPP_PENDING_UNKNOWN=false

# ── Configuration générale ──────────────────────────────────────────────────
# Niveau de log : error | warn | info | debug
CPADMIN_LOGLEVEL=info

# Langue par défaut de l'interface : fr | en
#CPADMIN_LANGUAGE=fr

# Nom du CPO affiché dans l'interface
#CPADMIN_CPO_NAME=Mon CPO

# ── Notifications e-mail (optionnel) ────────────────────────────────────────
#CPADMIN_MAIL_ENABLED=true
#CPADMIN_MAIL_HOST=smtp.example.com
#CPADMIN_MAIL_PORT=587
#CPADMIN_MAIL_SECURE=false
#CPADMIN_MAIL_USER=user@example.com
#CPADMIN_MAIL_PASS=password
#CPADMIN_MAIL_FROM=noreply@cpadmin.example.com

# ── Notifications Web Push (optionnel) ──────────────────────────────────────
# Générer les clés VAPID : npx web-push generate-vapid-keys
#CPADMIN_WEBPUSH_ENABLED=true
#CPADMIN_VAPID_SUBJECT=mailto:admin@cpadmin.example.com
#CPADMIN_VAPID_PUBLIC_KEY=
#CPADMIN_VAPID_PRIVATE_KEY=

# ── Notifications Pushover (optionnel) ──────────────────────────────────────
#CPADMIN_PUSHOVER_ENABLED=true

# ── Authentification Google OAuth (optionnel) ────────────────────────────────
#CPADMIN_GOOGLE_AUTH_ENABLED=true
#CPADMIN_GOOGLE_CLIENT_ID=
#CPADMIN_GOOGLE_CLIENT_SECRET=

# ── Métriques Prometheus (optionnel) ────────────────────────────────────────
# Si défini, le endpoint GET /metrics exige ce token en Authorization: Bearer <token>
# Laisser vide pour un accès libre (réseau interne / Docker uniquement)
#CPADMIN_METRICS_TOKEN=
