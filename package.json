{
  "name": "ocpp-cp-admin",
  "version": "1.0.0",
  "description": "OCPP 1.6 Charge Point Management System (CSMS) for operating and monitoring EV charging infrastructure.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start-dev": "cross-env NODE_ENV=development node src/server.js",
    "start-watch": "cross-env NODE_ENV=development node --watch src/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"*.json\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"*.json\" \"*.js\"",
    "backup": "node scripts/backup.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit",
    "audit:secrets": "secretlint \"**/*\"",
    "audit:deps": "npm audit --audit-level=high"
  },
  "homepage": "https://github.com/WoCha-FR/ocpp-cp-admin#readme",
  "bugs": {
    "url": "https://github.com/WoCha-FR/ocpp-cp-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WoCha-FR/ocpp-cp-admin.git"
  },
  "keywords": [
    "ocpp",
    "ocpp-1.6",
    "csms",
    "charge-point",
    "charging-station",
    "ev-charging",
    "electric-vehicle",
    "websocket",
    "admin",
    "management",
    "nodejs"
  ],
  "author": "WoCha",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "better-sqlite3-session-store": "^0.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "i18next": "^26.0.8",
    "nodemailer": "^8.0.6",
    "ocpp-rpc": "2.1.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "prettier": "^3.8.3",
    "secretlint": "^12.3.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
